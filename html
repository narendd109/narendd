<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, shrink-to-fit=no">
  <title>NAREND | Keuangan Jajan</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
    }

    body {
      background: linear-gradient(145deg, #fef9e7 0%, #fdebd0 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.2rem;
    }

    .app-container {
      max-width: 520px;
      width: 100%;
      background: rgba(255, 250, 240, 0.9);
      backdrop-filter: blur(16px);
      background: #fffbf2;
      box-shadow: 0 30px 50px rgba(180, 100, 30, 0.15), 0 10px 25px rgba(0, 0, 0, 0.08);
      border-radius: 48px;
      padding: 1.8rem 1.6rem 2.2rem;
      border: 1px solid rgba(255, 215, 150, 0.7);
      transition: all 0.2s ease;
    }

    /* Header NAREND */
    .brand {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.8rem;
      flex-wrap: wrap;
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .n-icon {
      background: #d46b2c;
      color: white;
      font-weight: 800;
      font-size: 1.8rem;
      width: 48px;
      height: 48px;
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 14px rgba(212, 107, 44, 0.3);
      letter-spacing: 1px;
    }

    .app-title {
      font-size: 2.1rem;
      font-weight: 700;
      color: #4e2e1e;
      line-height: 1.1;
    }

    .app-sub {
      font-size: 0.8rem;
      color: #b45f3a;
      font-weight: 500;
      letter-spacing: 0.4px;
      margin-top: -2px;
    }

    .saldo-card {
      background: #fbe9d2;
      padding: 0.7rem 1.4rem;
      border-radius: 100px;
      background: #fce4c8;
      box-shadow: inset 0 1px 5px rgba(0,0,0,0.05);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 600;
      color: #5a3a24;
    }

    .saldo-amount {
      background: white;
      padding: 0.3rem 1rem;
      border-radius: 30px;
      font-size: 1.1rem;
      color: #2d5e2c;
      font-weight: 700;
    }

    /* Grid Menu 4 Jajan */
    .menu-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin: 1.6rem 0 1.8rem;
    }

    .menu-card {
      background: white;
      border-radius: 28px;
      padding: 1.2rem 0.7rem 0.9rem;
      box-shadow: 0 12px 20px -10px rgba(150, 90, 30, 0.2);
      transition: all 0.25s ease;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      border: 1px solid #ffe0b5;
      background: #fffaf2;
      position: relative;
      user-select: none;
    }

    .menu-card:active {
      transform: scale(0.96);
      background: #fff3df;
      box-shadow: 0 6px 12px rgba(180, 100, 20, 0.3);
      border-color: #d49b4c;
    }

    /* Efek klik untuk desktop dan mobile */
    .menu-card:hover {
      background: #fff7ea;
      border-color: #cf9f5e;
      box-shadow: 0 18px 24px -10px #c1843c;
    }

    .emoji-menu {
      font-size: 3rem;
      margin-bottom: 0.3rem;
      filter: drop-shadow(0 6px 6px rgba(0,0,0,0.15));
    }

    .menu-name {
      font-weight: 700;
      font-size: 1.1rem;
      color: #4f2d14;
      margin: 0.2rem 0 0.1rem;
    }

    .menu-price {
      background: #fceae3;
      padding: 0.3rem 1rem;
      border-radius: 20px;
      font-weight: 700;
      color: #b9451a;
      font-size: 0.9rem;
      margin-top: 0.3rem;
      display: inline-flex;
      align-items: center;
      gap: 2px;
    }

    /* Riwayat transaksi */
    .history-panel {
      background: #fef5e7;
      border-radius: 28px;
      padding: 1rem 1rem 0.8rem;
      margin: 1.5rem 0 1.2rem;
      border: 1px solid #ebd3b2;
    }

    .history-title {
      display: flex;
      justify-content: space-between;
      font-weight: 700;
      color: #633c1c;
      margin-bottom: 0.7rem;
      font-size: 0.95rem;
    }

    .history-list {
      max-height: 135px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.85rem;
      padding-right: 4px;
    }

    .history-item {
      display: flex;
      justify-content: space-between;
      background: white;
      padding: 0.5rem 0.8rem;
      border-radius: 16px;
      border-left: 4px solid #d48c3c;
      color: #3b2a1a;
      align-items: center;
      box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

    .history-left {
      display: flex;
      flex-direction: column;
    }

    .history-food {
      font-weight: 700;
    }

    .history-time {
      font-size: 0.7rem;
      color: #996b4a;
    }

    .history-cost {
      font-weight: 700;
      color: #b1441e;
    }

    .reset-area {
      display: flex;
      justify-content: flex-end;
    }

    .reset-btn {
      background: none;
      border: 1px solid #deb887;
      background: #fff7ed;
      padding: 0.55rem 1.6rem;
      border-radius: 30px;
      font-weight: 600;
      color: #7b4a2c;
      cursor: pointer;
      transition: 0.2s;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
      letter-spacing: 0.3px;
    }

    .reset-btn:active {
      background: #f5d5b8;
      border-color: #b87333;
      color: #4d2e16;
    }

    .empty-message {
      color: #b2947c;
      font-style: italic;
      font-size: 0.8rem;
      padding: 0.4rem;
      text-align: center;
    }

    /* Footer kecil */
    .footer-note {
      text-align: center;
      margin-top: 1rem;
      color: #b2906b;
      font-size: 0.7rem;
      font-weight: 500;
    }
  </style>
</head>
<body>
  <div class="app-container">
    <!-- Brand NAREND -->
    <div class="brand">
      <div class="logo-area">
        <div class="n-icon">N</div>
        <div>
          <div class="app-title">NAREND</div>
          <div class="app-sub">Keuangan Jajan</div>
        </div>
      </div>
      <div class="saldo-card">
        <span>💰 Saldo</span>
        <span class="saldo-amount" id="saldoDisplay">Rp50.000</span>
      </div>
    </div>

    <!-- Grid Menu 4 item: mie ayam, bakso, seblak, martabak -->
    <div class="menu-grid">
      <!-- Mie Ayam -->
      <div class="menu-card" data-menu="Mie Ayam" data-harga="12000">
        <div class="emoji-menu">🍜</div>
        <div class="menu-name">Mie Ayam</div>
        <div class="menu-price">Rp12.000</div>
      </div>
      <!-- Bakso -->
      <div class="menu-card" data-menu="Bakso" data-harga="10000">
        <div class="emoji-menu">🍲</div>
        <div class="menu-name">Bakso</div>
        <div class="menu-price">Rp10.000</div>
      </div>
      <!-- Seblak -->
      <div class="menu-card" data-menu="Seblak" data-harga="8000">
        <div class="emoji-menu">🥘</div>
        <div class="menu-name">Seblak</div>
        <div class="menu-price">Rp8.000</div>
      </div>
      <!-- Martabak -->
      <div class="menu-card" data-menu="Martabak" data-harga="15000">
        <div class="emoji-menu">🫓</div>
        <div class="menu-name">Martabak</div>
        <div class="menu-price">Rp15.000</div>
      </div>
    </div>

    <!-- Riwayat Transaksi -->
    <div class="history-panel">
      <div class="history-title">
        <span>📋 Riwayat Jajan</span>
        <span id="totalPengeluaran">Rp0</span>
      </div>
      <div class="history-list" id="historyContainer">
        <div class="empty-message">Belum ada transaksi. Klik menu di atas!</div>
      </div>
    </div>

    <!-- Reset / hapus riwayat -->
    <div class="reset-area">
      <button class="reset-btn" id="resetButton">
        <span>🗑️</span> Reset Riwayat
      </button>
    </div>
    <div class="footer-note">
      NAREND · catat jajan praktis
    </div>
  </div>

  <script>
    (function() {
      // --- Data Keuangan ---
      let saldo = 50000;                 // Saldo awal Rp50.000
      const transaksiList = [];         // Array of objects: { menu, harga, waktu }

      // --- Elemen HTML ---
      const saldoDisplay = document.getElementById('saldoDisplay');
      const historyContainer = document.getElementById('historyContainer');
      const totalPengeluaranEl = document.getElementById('totalPengeluaran');
      const resetButton = document.getElementById('resetButton');
      const menuCards = document.querySelectorAll('.menu-card');

      // --- Fungsi format Rupiah ---
      function formatRupiah(angka) {
        return 'Rp' + angka.toLocaleString('id-ID');
      }

      // --- Update tampilan saldo ---
      function updateSaldoUI() {
        saldoDisplay.textContent = formatRupiah(saldo);
      }

      // --- Hitung total pengeluaran dari transaksiList ---
      function hitungTotalPengeluaran() {
        return transaksiList.reduce((total, item) => total + item.harga, 0);
      }

      // --- Render ulang riwayat transaksi ke HTML ---
      function renderHistory() {
        // Kosongkan container
        historyContainer.innerHTML = '';

        if (transaksiList.length === 0) {
          // Tampilkan pesan kosong
          historyContainer.innerHTML = '<div class="empty-message">Belum ada transaksi. Klik menu di atas!</div>';
          totalPengeluaranEl.textContent = 'Rp0';
          return;
        }

        // Loop setiap transaksi (dari paling baru di atas? akan ditampilkan sesuai urutan penambahan,
        // tapi biasanya yang baru di atas. Kita balik agar yang terbaru di atas)
        const reversed = [...transaksiList].reverse();
        for (let trx of reversed) {
          const itemDiv = document.createElement('div');
          itemDiv.className = 'history-item';

          // Format waktu (jam:menit)
          const waktuStr = trx.waktu.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

          itemDiv.innerHTML = `
            <div class="history-left">
              <span class="history-food">${trx.menu}</span>
              <span class="history-time">${waktuStr}</span>
            </div>
            <div class="history-cost">-${formatRupiah(trx.harga)}</div>
          `;

          historyContainer.appendChild(itemDiv);
        }

        // Update total pengeluaran di judul riwayat
        const total = hitungTotalPengeluaran();
        totalPengeluaranEl.textContent = formatRupiah(total);
      }

      // --- Fungsi tambah transaksi (jika saldo cukup) ---
      function tambahTransaksi(menu, harga) {
        // Validasi saldo cukup
        if (saldo < harga) {
          alert(`❌ Saldo tidak cukup untuk membeli ${menu}.\nButuh ${formatRupiah(harga)}, sisa saldo ${formatRupiah(saldo)}.`);
          return false; // gagal
        }

        // Kurangi saldo
        saldo -= harga;

        // Catat transaksi dengan waktu sekarang
        const transaksiBaru = {
          menu: menu,
          harga: harga,
          waktu: new Date()
        };
        transaksiList.push(transaksiBaru);

        // Update UI
        updateSaldoUI();
        renderHistory();

        // Feedback kecil (bisa juga suara/animasi opsional, alert ringan)
        // Tidak pakai alert agar tidak mengganggu, cukup perubahan visual.
        return true;
      }

      // --- Reset semua riwayat & kembalikan saldo ke awal ---
      function resetKeuangan() {
        if (transaksiList.length === 0) {
          alert('📭 Riwayat sudah kosong.');
          return;
        }

        // Konfirmasi sederhana
        const konfirmasi = confirm('⚠️ Reset seluruh riwayat jajan dan kembalikan saldo ke Rp50.000?');
        if (!konfirmasi) return;

        // Kembalikan saldo ke 50000
        saldo = 50000;
        // Kosongkan array transaksi
        transaksiList.length = 0;

        // Perbarui tampilan
        updateSaldoUI();
        renderHistory();
      }

      // --- Event Listener untuk setiap menu card (bisa diklik) ---
      menuCards.forEach(card => {
        card.addEventListener('click', function(e) {
          // Ambil data dari atribut dataset
          const menu = this.dataset.menu;
          const harga = parseInt(this.dataset.harga, 10);

          if (!menu || isNaN(harga)) {
            console.warn('Data menu tidak valid');
            return;
          }

          // Panggil fungsi tambah transaksi
          tambahTransaksi(menu, harga);

          // Efek tambahan: sedikit getar atau animasi? sudah ada scale di CSS.
          // Bisa tambahkan class sementara (opsional)
          this.style.transition = '0.15s';
          this.style.transform = 'scale(0.94)';
          setTimeout(() => {
            this.style.transform = '';
          }, 120);
        });

        // Untuk aksesibilitas: tambahkan keyboard support (Enter / Space)
        card.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            this.click();
          }
        });
        // Buat card bisa fokus (tabindex)
        card.setAttribute('tabindex', '0');
        card.setAttribute('role', 'button');
        card.setAttribute('aria-label', card.dataset.menu + ' harga ' + card.dataset.harga);
      });

      // --- Event Listener tombol reset ---
      resetButton.addEventListener('click', resetKeuangan);

      // --- Inisialisasi tampilan pertama kali ---
      function inisialisasi() {
        updateSaldoUI();
        renderHistory();
        // Pastikan transaksiList kosong di awal (default)
        // saldo sudah 50000
      }

      inisialisasi();

      // Optional: menyimpan data ke localStorage? Tidak diminta, jadi hanya di memori.
      // Namun bisa ditambahkan jika perlu. Untuk sekarang tetap interaktif.

      // Tambahan kecil: jika saldo kurang, bisa muncul peringatan halus, 
      // tetapi sudah ditangani di fungsi tambahTransaksi.

    })();
  </script>
</body>
</html>
